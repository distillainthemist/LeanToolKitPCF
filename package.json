{
  "name": "leantoolkit-pcf",
  "version": "0.1.0",
  "description": "LeanToolKit — a suite of lean-board PowerApps Component Framework controls with a shared design system and common JSON contracts",
  "license": "MIT",
  "author": "Ben O'Brien",
  "scripts": {
    "prestart": "find . -name .DS_Store -not -path './node_modules/*' -delete 2>/dev/null || true",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=8192 pcf-scripts build",
    "clean": "pcf-scripts clean",
    "rebuild": "cross-env NODE_OPTIONS=--max-old-space-size=8192 pcf-scripts rebuild",
    "start": "pcf-scripts start",
    "start:watch": "pcf-scripts start watch",
    "refreshTypes": "pcf-scripts refreshTypes"
  },
  "devDependencies": {
    "@types/node": "^18.19.0",
    "@types/powerapps-component-framework": "^1.3.6",
    "cross-env": "^10.1.0",
    "pcf-scripts": "^1",
    "pcf-start": "^1",
    "typescript": "^4.9.5"
  }
}
